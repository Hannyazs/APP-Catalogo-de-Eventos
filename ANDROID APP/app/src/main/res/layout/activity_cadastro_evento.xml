<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".CadastroEventoActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingHorizontal="24dp"
            android:paddingVertical="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cadastro de Evento"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/azul_primary"
                android:layout_marginBottom="32dp"/>

            <EditText
                android:id="@+id/etNome"
                android:hint="Nome do evento"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:drawable/editbox_background"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etData"
                android:hint="Data"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:drawable/editbox_background"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etHorario"
                android:hint="Horário"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:drawable/editbox_background"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etLocal"
                android:hint="Local"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@android:drawable/editbox_background"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="12dp"/>

            <EditText
                android:id="@+id/etDescricao"
                android:hint="Descrição"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="100dp"
                android:gravity="top"
                android:background="@android:drawable/editbox_background"
                android:padding="16dp"
                android:layout_marginBottom="24dp"/>

            <Button
                android:id="@+id/btnSalvar"
                android:text="Salvar Evento"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:backgroundTint="@color/azul_primary"
                android:textColor="@color/white"
                android:textStyle="bold"/>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>